# EasyCloud Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# JWT Secret (REQUIRED, min 32 chars)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Database
DB_USERNAME=root
DB_PASSWORD=

# Redis (optional, defaults to localhost:6379)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Admin Password Hash (for initial setup)
# Generate with: echo -n "your_password!@#%!s!0" | md5sum
ADMIN_PWD_HASH=

# SMS (optional)
SMS_APPID=
SMS_APPKEY=

# Payment (optional)
WXPAY_KEY=
QQPAY_KEY=

# Mail (optional)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
